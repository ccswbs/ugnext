{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "graduate-degrees.schema.json",
  "title": "Graduate Degrees",
  "description": "Graduate degrees offered at the University of Guelph",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "description": "A unique id for the degree",
        "type": "string"
      },
      "name": {
        "description": "The name of the degree",
        "type": "string"
      },
      "acronym": {
        "description": "A short name/acronym for the degree",
        "type": "string"
      }
    },
    "required": ["id", "name"],
    "additionalProperties": false
  }
}
