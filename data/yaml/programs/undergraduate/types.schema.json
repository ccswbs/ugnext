{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "undergraduate-program-types.schema.json",
  "title": "Undergraduate Program Types",
  "description": "A Undergraduate program type offered at the University of Guelph",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "description": "A unique id for the type",
        "type": "string"
      },
      "name": {
        "description": "The name of the type",
        "type": "string"
      }
    },
    "required": ["id", "name"],
    "additionalProperties": false
  }
}
